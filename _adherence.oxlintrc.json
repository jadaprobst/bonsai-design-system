        "message": "<HabitCard> color must be one of 'green' | 'gold' | 'lavender' | 'sky' | 'terra' | 'earth'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HabitCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<HabitCard> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|helper|error|leftIcon|rightIcon|size|disabled|id|style|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, helper, error, leftIcon, rightIcon, size, disabled, id, style, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodSelector'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|size|showLabels|style|key|ref|className|style|children)$/]",
        "message": "<MoodSelector> doesn't accept that prop. Declared props: value, onChange, size, showLabels, style."
      },
