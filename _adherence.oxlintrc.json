        "message": "<MoodSelector> value must be one of 'great' | 'good' | 'okay' | 'low' | 'stressed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodSelector'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
